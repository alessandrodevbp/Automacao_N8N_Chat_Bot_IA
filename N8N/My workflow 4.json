    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\n\n\nconst produtos = allItems.filter(i => i.json.sku && i.json.ingredientes);\nconst estoque  = allItems.filter(i => i.json.sku_ingrediente);\nconst sops     = allItems.filter(i => i.json.id && String(i.json.id).startsWith('SOP'));\nconst faq      = allItems.filter(i => i.json.id && String(i.json.id).startsWith('FAQ'));\nconst vendas   = allItems.filter(i => i.json.pedido_id);\n\nconst blocoCardapio = produtos\n  .filter(i => i.json.ativo === 'Sim')\n  .map(i => {\n    const preco = typeof i.json.preco_venda === 'number'\n      ? i.json.preco_venda.toFixed(2)\n      : parseFloat(String(i.json.preco_venda).replace(',', '.')) || i.json.preco_venda;\n    return `• [${i.json.sku}] ${i.json.nome} — ${i.json.categoria}\n  💰 Preço: R$ ${preco}\n  🥗 Ingredientes: ${i.json.ingredientes}\n  🥛 Lactose: ${i.json.contem_lactose} | 🌱 Vegetariano: ${i.json.vegetariano} | 🛵 Delivery: ${i.json.disponivel_delivery}`;\n  }).join('\\n\\n');\n\nconst blocoEstoque = estoque.map(i =>\n  `• [${i.json.sku_ingrediente}] ${i.json.nome} — ${i.json.qtd_atual} ${i.json.unidade} | Status: ${i.json.status}`\n).join('\\n');\n\nconst blocoSops = sops.map(i =>\n  `• [${i.json.id}] ${i.json.categoria} — ${i.json.pergunta}\\n  ➜ ${i.json.resposta}`\n).join('\\n\\n');\n\nconst blocoFaq = faq.map(i =>\n  `• [${i.json.id}] ${i.json.pergunta}\\n  ➜ ${i.json.resposta}`\n).join('\\n\\n');\n\nconst resumoPorProduto = {};\nvendas.forEach(i => {\n  const nome  = i.json.produto || i.json.sku;\n  const qtd   = parseFloat(i.json.qtd) || 0;\n  const total = parseFloat(i.json.total) || 0;\n  if (!resumoPorProduto[nome]) resumoPorProduto[nome] = { qtd: 0, receita: 0 };\n  resumoPorProduto[nome].qtd     += qtd;\n  resumoPorProduto[nome].receita += total;\n});\n\nconst blocoResumoVendas = Object.entries(resumoPorProduto)\n  .sort((a, b) => b[1].qtd - a[1].qtd)\n  .map(([nome, v]) =>\n    `• ${nome} — ${v.qtd} vendidos | Receita: R$ ${v.receita.toFixed(2)}`\n  ).join('\\n');\n\nconst ultimosPedidos = vendas.slice(-10).reverse().map(i =>\n  `• [${i.json.pedido_id}] ${i.json.produto} x${i.json.qtd} — R$ ${i.json.total} | ${i.json.canal} | ${i.json.forma_pagamento}`\n).join('\\n');\n\nconst contexto = `\n=== CARDÁPIO NOLA ===\n${blocoCardapio}\n\n=== ESTOQUE DE INGREDIENTES ===\n${blocoEstoque}\n\n=== PROCEDIMENTOS OPERACIONAIS (SOPs) ===\n${blocoSops}\n\n=== PERGUNTAS FREQUENTES (FAQ) ===\n${blocoFaq}\n\n=== HISTÓRICO DE VENDAS ===\n📦 PRODUTOS MAIS VENDIDOS:\n${blocoResumoVendas}\n\n🕐 ÚLTIMOS 10 PEDIDOS:\n${ultimosPedidos}\n`.trim();\n\nconst mensagem = $input.first().json.message;\n\nreturn [{\n  json: {\n    contexto,\n    message: mensagem\n  }\n}];\nconst texto = $input.first().json.output;\n\nconst limpo = texto\n  .replace(/\\*\\*(.*?)\\*\\*/g, '$1')  // remove **negrito**\n  .replace(/\\*(.*?)\\*/g, '$1')      // remove *itálico*\n  .replace(/_(.*?)_/g, '$1')        // remove _underline_\n  .replace(/`(.*?)`/g, '$1')        // remove `código`\n  .replace(/\\[(.*?)\\]\\(.*?\\)/g, '$1') // remove [links](url)\n\nreturn [{ json: { \n  output: limpo,\n  chat_id: $('Telegram Trigger').first().json.message.chat.id\n}}];"
      },
